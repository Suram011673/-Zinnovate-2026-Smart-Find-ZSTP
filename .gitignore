# Track source, configs, assets, and docs. Ignore generated deps, caches, secrets, and build output.

# --- Python (deps & bytecode — never commit venv) ---
.venv/
venv/
env/
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
*.egg-info/
.eggs/
*.egg
build/
dist/

# --- Node ---
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# --- Frontend build (regenerate: cd frontend && npm run build) ---
frontend/dist/

# --- Env / secrets ---
.env
.env.local
.env.*.local
*.pem

# --- Logs & runtime ---
*.log

# --- Tooling / tests ---
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
htmlcov/

# --- IDE / OS (personal machine settings — remove a line below if your team commits shared configs) ---
.idea/
.vscode/
*.swp
.DS_Store
Thumbs.db
